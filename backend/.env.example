# hollr.to backend — environment variables (v4.0.0)
# Copy to .env and fill in values before running locally.
# On Fly.io, use: flyctl secrets set KEY=value -a hollr-api

# HTTP port (Fly.io sets this automatically)
PORT=3000

# Absolute path for SQLite database and uploaded files
# On Fly.io: /data (persistent volume)
DATA_DIR=/data

# Server-side secret for AES-256 encryption of API keys and OAuth tokens
# Generate with: openssl rand -hex 32
ENCRYPTION_SECRET=CHANGE_ME_generate_with_openssl_rand_-hex_32

# Express session secret (for OAuth state during X login)
# Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_generate_with_openssl_rand_-hex_32

# ── Platform email (used when user has no own Resend key) ─────────────────────
# Get a free Resend key at https://resend.com
PLATFORM_RESEND_KEY=re_YOUR_RESEND_API_KEY_HERE
PLATFORM_FROM_EMAIL=hollr <yo@hollr.to>

# ── URLs ──────────────────────────────────────────────────────────────────────
# Public URL of this backend (used to build upload URLs + OAuth callbacks)
BASE_URL=https://api.hollr.to

# Public URL of the frontend (used to build magic links + OAuth redirects)
FRONTEND_URL=https://hollr.to

# Extra allowed CORS origins (comma-separated, no spaces)
ALLOWED_ORIGINS=

# Node environment
NODE_ENV=production

# ── X (Twitter) OAuth 2.0 (optional) ─────────────────────────────────────────
# Create an app at https://developer.twitter.com/en/portal/dashboard
# Set callback URL to: https://api.hollr.to/api/auth/x/callback
X_CLIENT_ID=YOUR_X_CLIENT_ID
X_CLIENT_SECRET=YOUR_X_CLIENT_SECRET
